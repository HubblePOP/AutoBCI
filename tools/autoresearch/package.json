    "start:check:constitution-sync": "node dist/check_constitution_sync.js"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.118.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22"
  }
}
