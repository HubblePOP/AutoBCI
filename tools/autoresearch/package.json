{
  "name": "bci-autoresearch",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/run_iteration.ts",
    "campaign": "tsx src/launch_campaign.ts",
    "queue:compile": "tsx src/queue_compiler.ts",
    "check:constitution-sync": "tsx src/check_constitution_sync.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/run_iteration.js",
